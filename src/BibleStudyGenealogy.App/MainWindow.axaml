<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="820"
        x:Class="BibleStudyGenealogy.App.MainWindow"
        Title="ScriptureLine"
        Width="1280"
        Height="820"
        MinWidth="1040"
        MinHeight="680">
    <Grid ColumnDefinitions="260,*">
        <Border Grid.Column="0"
                Background="{StaticResource InkGreenBrush}"
                Padding="24">
            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Spacing="4">
                    <TextBlock Text="ScriptureLine"
                               Classes="display"
                               Foreground="{StaticResource CreamBrush}"
                               FontSize="30" />
                    <TextBlock Text="Persönlicher Studienraum"
                               Foreground="#BDAE8D"
                               FontSize="13" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Margin="0,36,0,0"
                            Spacing="8">
                    <Button x:Name="NavDashboardButton" Classes="nav active" Content="Dashboard" Click="NavigateDashboardButton_Click" ToolTip.Tip="Aktuelle Gesamtansicht" />
                    <Button x:Name="NavPeopleButton" Classes="nav" Content="Personen" Click="NavigatePeopleButton_Click" ToolTip.Tip="Personen suchen, anlegen und bearbeiten." />
                    <Button x:Name="NavFamilyTreeButton" Classes="nav" Content="Stammbaum" Click="NavigateFamilyTreeButton_Click" ToolTip.Tip="Familienbeziehungen und Stammbaum-Vorschau." />
                    <Button x:Name="NavTimelineButton" Classes="nav" Content="Zeitstrahl" Click="NavigateTimelineButton_Click" ToolTip.Tip="Ereignisse chronologisch ansehen." />
                    <Button x:Name="NavMapButton" Classes="nav" Content="Karte (bald)" Click="NavigateMapButton_Click" ToolTip.Tip="Kartenansicht ist noch nicht umgesetzt." />
                    <Button x:Name="NavEventsButton" Classes="nav" Content="Ereignisse" Click="NavigateEventsButton_Click" ToolTip.Tip="Ereignisse erfassen und bearbeiten." />
                    <Button x:Name="NavPlacesButton" Classes="nav" Content="Orte (bald)" Click="NavigatePlacesButton_Click" ToolTip.Tip="Ortsverwaltung ist noch nicht umgesetzt." />
                    <Button x:Name="NavBibleReferencesButton" Classes="nav" Content="Bibelstellen" Click="NavigateBibleReferencesButton_Click" ToolTip.Tip="Bibelstellen erfassen und kommentieren." />
                    <Button x:Name="NavMediaButton" Classes="nav" Content="Mediathek" Click="NavigateMediaButton_Click" ToolTip.Tip="Bilder, PDFs und Projektdateien importieren." />
                    <Button x:Name="NavResearchQuestionsButton" Classes="nav" Content="Forschungsfragen (bald)" Click="NavigateResearchQuestionsButton_Click" ToolTip.Tip="Forschungsfragen sind noch nicht umgesetzt." />
                </StackPanel>

                <Border Grid.Row="2"
                        Classes="dark-card"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="SidebarProjectTitle"
                                   Text="Studienmodus"
                                   Foreground="{StaticResource CreamBrush}"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="SidebarProjectStatus"
                                   Text="Kein Projekt geladen"
                                   Foreground="#BDAE8D"
                                   FontSize="12" />
                        <Button Classes="secondary"
                                Content="Projekt öffnen"
                                Click="OpenProjectButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1"
                      Background="{StaticResource PetrolBrush}">
            <StackPanel Margin="34"
                        Spacing="24">
                <Border x:Name="DashboardHeroView"
                        CornerRadius="8"
                        ClipToBounds="True">
                    <Grid MinHeight="360">
                        <Image Source="avares://BibleStudyGenealogy.App/Assets/Images/Dashboardpicture.png"
                               Stretch="UniformToFill" />
                        <Border Background="#FFF1D8CC"
                                CornerRadius="8"
                                Margin="34"
                                Padding="28"
                                MaxWidth="480"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Willkommen bei"
                                           Classes="display"
                                           FontSize="34"
                                           Foreground="{StaticResource InkGreenBrush}" />
                                <TextBlock Text="ScriptureLine"
                                           Classes="display"
                                           FontSize="58"
                                           Foreground="{StaticResource TerracottaBrush}" />
                                <TextBlock Text="Deine Reise durch die Heilige Schrift"
                                           Foreground="{StaticResource InkGreenBrush}"
                                           FontSize="19"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="„Dein Wort ist meines Fußes Leuchte und ein Licht auf meinem Wege.“"
                                           Classes="body"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="Psalm 119:105"
                                           Foreground="{StaticResource TerracottaBrush}"
                                           FontWeight="SemiBold" />
                                <TextBox x:Name="ProjectNameTextBox"
                                         Classes="project-name"
                                         Width="320"
                                         HorizontalAlignment="Left"
                                         PlaceholderText="Projektname"
                                         Text="Mein Bibelprojekt" />
                                <StackPanel Orientation="Horizontal"
                                            Spacing="12">
                                    <Button Classes="primary"
                                            Content="Neues Projekt"
                                            Click="CreateProjectButton_Click" />
                                    <Button Classes="secondary"
                                            Content="Projekt öffnen"
                                            Click="OpenProjectButton_Click" />
                                </StackPanel>
                                <TextBlock x:Name="ProjectStatusText"
                                           Text="Wähle einen Speicherort, um dein erstes lokales Studienprojekt anzulegen."
                                           Classes="body"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid x:Name="DashboardStatsView"
                      ColumnDefinitions="1.05*,*,*,*"
                      ColumnSpacing="16">
                    <Border Grid.Column="0" Classes="card">
                        <StackPanel Spacing="9">
                            <TextBlock Text="Projektübersicht" Foreground="{StaticResource InkGreenBrush}" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="Personen" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="PersonCountText" Text="0" Classes="display" FontSize="34" />
                            <TextBlock x:Name="EventCountText" Text="0 Ereignisse" Classes="body" FontSize="12" TextWrapping="Wrap" />
                            <TextBlock x:Name="BibleReferenceCountText" Text="0 Bibelstellen" Classes="body" FontSize="12" TextWrapping="Wrap" />
                            <TextBlock x:Name="MediaFileCountText" Text="0 Medien" Classes="body" FontSize="12" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Classes="card">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Zuletzt bearbeitet" Foreground="{StaticResource InkGreenBrush}" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock x:Name="LastEditedText" Text="Noch keine Person bearbeitet" Classes="body" TextWrapping="Wrap" />
                            <Button Classes="secondary" Content="Erste Person anlegen" Click="CreatePersonButton_Click" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Classes="card">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Zeitleiste" Foreground="{StaticResource InkGreenBrush}" FontSize="18" FontWeight="SemiBold" />
                            <ListBox x:Name="TimelineListBox"
                                     MinHeight="96" />
                            <TextBlock x:Name="TimelineEmptyText"
                                       Text="Noch keine Ereignisse für die Zeitleiste."
                                       Classes="body"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="RelationshipCountText" Text="0 Beziehungen vorbereitet" Classes="body" FontSize="12" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Classes="card">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Karte" Foreground="{StaticResource InkGreenBrush}" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock x:Name="PlaceCountText" Text="0 Orte" Classes="display" FontSize="34" />
                            <TextBlock Text="Orte und Reisen werden später hier sichtbar." Classes="body" FontSize="12" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="DashboardProjectView"
                      ColumnDefinitions="1.1*,0.9*"
                      ColumnSpacing="18">
                    <Border Grid.Column="0"
                            Classes="card">
                        <StackPanel Spacing="18">
                            <TextBlock Text="Personenakte"
                                       Classes="display"
                                       FontSize="28" />
                            <Grid ColumnDefinitions="120,*"
                                  ColumnSpacing="18">
                                <Border Width="112"
                                        Height="132"
                                        CornerRadius="8"
                                        Background="{StaticResource ParchmentTintBrush}"
                                        BorderBrush="{StaticResource SoftLineBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="Bild"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Spacing="10">
                                    <TextBlock x:Name="CurrentProjectTitle"
                                               Text="Noch kein Projekt geöffnet"
                                               Foreground="{StaticResource InkGreenBrush}"
                                               FontSize="22"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="CurrentProjectDetails"
                                               Text="Lege ein lokales Projekt an oder öffne einen bestehenden Projektordner."
                                               Classes="body"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Border Background="{StaticResource ParchmentTintBrush}" CornerRadius="6" Padding="10,6">
                                            <TextBlock Text="Überblick" Foreground="{StaticResource InkGreenBrush}" />
                                        </Border>
                                        <Border Background="#F4DFAF" CornerRadius="6" Padding="10,6">
                                            <TextBlock Text="Familie" Foreground="{StaticResource InkGreenBrush}" />
                                        </Border>
                                        <Border Background="#F4DFAF" CornerRadius="6" Padding="10,6">
                                            <TextBlock Text="Notizen" Foreground="{StaticResource InkGreenBrush}" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Classes="dark-card">
                        <StackPanel Spacing="18">
                            <TextBlock Text="Nächste Schritte"
                                       Classes="section-title" />
                            <Border Background="#284744"
                                    CornerRadius="8"
                                    Padding="14">
                                <TextBlock Text="Projekt anlegen"
                                           Foreground="{StaticResource CreamBrush}"
                                           FontWeight="SemiBold" />
                            </Border>
                            <Border Background="#284744"
                                    CornerRadius="8"
                                    Padding="14">
                                <TextBlock Text="Erste Person erfassen"
                                           Foreground="{StaticResource CreamBrush}"
                                           FontWeight="SemiBold" />
                            </Border>
                            <Border Background="#284744"
                                    CornerRadius="8"
                                    Padding="14">
                                <TextBlock Text="Beziehungen und Quellen ergänzen"
                                           Foreground="{StaticResource CreamBrush}"
                                           FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border x:Name="DashboardTreePreviewView"
                        Classes="dark-card">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="20">
                        <StackPanel Spacing="7">
                            <TextBlock Text="Stammbaum-Vorschau"
                                       Classes="section-title" />
                            <TextBlock x:Name="TreePreviewText"
                                       Text="Wähle eine Person aus, um Eltern, Partner und Kinder als einfache Vorschau zu sehen."
                                       Foreground="#BDAE8D"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                x:Name="CreatePersonButton"
                                Classes="primary"
                                Content="Person anlegen"
                                Click="CreatePersonButton_Click"
                                IsEnabled="False"
                                VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Grid x:Name="DashboardActionsView"
                      ColumnDefinitions="*,*,1.35*"
                      ColumnSpacing="18">
                    <Border Classes="card">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Offene Aufgaben"
                                       Foreground="{StaticResource InkGreenBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Es gibt noch keine offenen Aufgaben."
                                       Classes="body"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Classes="card">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Forschungsfragen"
                                       Foreground="{StaticResource InkGreenBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="ResearchQuestionCountText"
                                       Text="0 offene Fragen"
                                       Classes="body"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Schnellzugriff"
                                       Foreground="{StaticResource InkGreenBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="12">
                                <Button x:Name="QuickAddPersonButton"
                                        Classes="primary"
                                        Content="Person anlegen"
                                        Click="CreatePersonButton_Click"
                                        IsEnabled="False" />
                                <Button x:Name="QuickAddPlaceButton"
                                        Classes="secondary"
                                        Content="Ort anlegen (bald)"
                                        ToolTip.Tip="Ortsverwaltung ist noch nicht umgesetzt."
                                        IsEnabled="False" />
                                <Button x:Name="QuickAddEventButton"
                                        Classes="secondary"
                                        Content="Ereignis erfassen"
                                        Click="CreateEventButton_Click"
                                        IsEnabled="False" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border x:Name="TimelineView"
                        Classes="card">
                    <Grid ColumnDefinitions="0.95*,1.05*"
                          ColumnSpacing="18">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Zeitstrahl"
                                       Classes="display"
                                       FontSize="30" />
                            <TextBlock Text="Chronologische Sicht auf alle Ereignisse oder auf die aktuell ausgewählte Person."
                                       Classes="body"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="10">
                                <Border Background="{StaticResource ParchmentTintBrush}" CornerRadius="6" Padding="10,6">
                                    <TextBlock Text="Alle Ereignisse" Foreground="{StaticResource InkGreenBrush}" />
                                </Border>
                                <Border Background="#F4DFAF" CornerRadius="6" Padding="10,6">
                                    <TextBlock Text="Aktuelle Person" Foreground="{StaticResource InkGreenBrush}" />
                                </Border>
                            </StackPanel>
                            <Button Classes="secondary"
                                    Content="Ereignis erfassen"
                                    Click="CreateEventButton_Click" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Spacing="12">
                            <TextBlock Text="Einträge"
                                       Foreground="{StaticResource InkGreenBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <ListBox x:Name="TimelineModuleListBox"
                                     MinHeight="260" />
                            <TextBlock x:Name="TimelineModuleEmptyText"
                                       Text="Noch keine Ereignisse für die Zeitleiste."
                                       Classes="body"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid x:Name="PeopleView"
                      ColumnDefinitions="0.9*,1.1*"
                      ColumnSpacing="18">
                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Personen"
                                       Classes="display"
                                       FontSize="28" />
                            <TextBox x:Name="PersonSearchTextBox"
                                     Classes="project-name"
                                     PlaceholderText="Person suchen"
                                     TextChanged="PersonSearchTextBox_TextChanged" />
                            <ListBox x:Name="PeopleListBox"
                                     MinHeight="260"
                                     SelectionChanged="PeopleListBox_SelectionChanged" />
                            <TextBlock x:Name="PeopleEmptyText"
                                       Text="Noch keine Personen erfasst."
                                       Classes="body" />
                        </StackPanel>
                    </Border>

                    <Border Classes="card">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Person bearbeiten"
                                       Classes="display"
                                       FontSize="28" />
                            <Grid ColumnDefinitions="*,*"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="10">
                                <TextBox x:Name="MainNameTextBox"
                                         Grid.Row="0"
                                         Grid.Column="0"
                                         Classes="project-name"
                                         PlaceholderText="Hauptname" />
                                <TextBox x:Name="AlternativeNamesTextBox"
                                         Grid.Row="0"
                                         Grid.Column="1"
                                         Classes="project-name"
                                         PlaceholderText="Alternative Namen" />
                                <TextBox x:Name="HebrewNameTextBox"
                                         Grid.Row="1"
                                         Grid.Column="0"
                                         Classes="project-name"
                                         PlaceholderText="Hebräischer Name" />
                                <TextBox x:Name="GreekNameTextBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Classes="project-name"
                                         PlaceholderText="Griechischer Name" />
                                <TextBox x:Name="NameMeaningTextBox"
                                         Grid.Row="2"
                                         Grid.Column="0"
                                         Classes="project-name"
                                         PlaceholderText="Namensbedeutung" />
                                <TextBox x:Name="PrimaryRoleTextBox"
                                         Grid.Row="2"
                                         Grid.Column="1"
                                         Classes="project-name"
                                         PlaceholderText="Rolle" />
                                <TextBox x:Name="OccupationTextBox"
                                         Grid.Row="3"
                                         Grid.Column="0"
                                         Classes="project-name"
                                         PlaceholderText="Beruf" />
                                <ComboBox x:Name="GenderComboBox"
                                          Grid.Row="3"
                                          Grid.Column="1"
                                          Classes="project-name" />
                                <ComboBox x:Name="PersonStatusComboBox"
                                          Grid.Row="4"
                                          Grid.Column="0"
                                          Classes="project-name" />
                                 <TextBox x:Name="ShortDescriptionTextBox"
                                          Grid.Row="4"
                                          Grid.Column="1"
                                          Classes="project-name"
                                          PlaceholderText="Kurzbeschreibung" />
                                <TextBox x:Name="BirthDateTextBox"
                                         Grid.Row="5"
                                         Grid.Column="0"
                                         Classes="project-name"
                                         PlaceholderText="Geburt, z. B. ca. 1380" />
                                <TextBox x:Name="DeathDateTextBox"
                                         Grid.Row="5"
                                         Grid.Column="1"
                                         Classes="project-name"
                                         PlaceholderText="Tod, z. B. 1449" />
                                <TextBox x:Name="LongDescriptionTextBox"
                                         Grid.Row="6"
                                         Grid.ColumnSpan="2"
                                         Classes="project-name"
                                         AcceptsReturn="True"
                                         MinHeight="88"
                                         TextWrapping="Wrap"
                                         PlaceholderText="Notizen" />
                            </Grid>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="12">
                                <Button x:Name="SavePersonButton"
                                        Classes="primary"
                                        Content="Person speichern"
                                        Click="SavePersonButton_Click"
                                        IsEnabled="False" />
                                <Button Classes="secondary"
                                        Content="Neue Eingabe"
                                        Click="CreatePersonButton_Click" />
                            </StackPanel>
                            <TextBlock x:Name="PersonFormStatusText"
                                       Text="Öffne oder erstelle zuerst ein Projekt."
                                       Classes="body" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="RelationshipsView"
                      ColumnDefinitions="1.05*,0.95*"
                      ColumnSpacing="18">
                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Familie"
                                       Classes="display"
                                       FontSize="28" />
                            <TextBlock Text="Beziehungen der ausgewählten Person"
                                       Classes="body" />
                            <ListBox x:Name="RelationshipsListBox"
                                     MinHeight="180"
                                     SelectionChanged="RelationshipsListBox_SelectionChanged" />
                            <TextBlock x:Name="RelationshipsEmptyText"
                                       Text="Wähle eine Person aus, um Beziehungen zu sehen."
                                       Classes="body" />
                        </StackPanel>
                    </Border>

                    <Border Classes="card">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Beziehung anlegen"
                                       Classes="display"
                                       FontSize="28" />
                            <ComboBox x:Name="RelationshipTargetComboBox"
                                      Classes="project-name" />
                            <ComboBox x:Name="RelationshipTypeComboBox"
                                      Classes="project-name" />
                            <ComboBox x:Name="RelationshipDirectionComboBox"
                                      Classes="project-name" />
                            <ComboBox x:Name="RelationshipCertaintyComboBox"
                                      Classes="project-name" />
                            <TextBox x:Name="RelationshipSourceNoteTextBox"
                                     Classes="project-name"
                                     PlaceholderText="Quelle oder Bibelstelle" />
                            <TextBox x:Name="RelationshipCommentTextBox"
                                     Classes="project-name"
                                     PlaceholderText="Kommentar"
                                     MinHeight="70"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap" />
                            <Button x:Name="SaveRelationshipButton"
                                    Classes="primary"
                                    Content="Beziehung speichern"
                                    Click="SaveRelationshipButton_Click"
                                    IsEnabled="False" />
                            <Button x:Name="ArchiveRelationshipButton"
                                    Classes="secondary"
                                    Content="Beziehung archivieren"
                                    Click="ArchiveRelationshipButton_Click"
                                    IsEnabled="False" />
                            <TextBlock x:Name="RelationshipFormStatusText"
                                       Text="Wähle zuerst eine Person aus."
                                       Classes="body" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border x:Name="FamilyTreeView"
                        Classes="card">
                    <Grid>
                        <Grid RowDefinitions="Auto,*"
                              RowSpacing="14">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="14">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Stammbaum"
                                               Classes="display"
                                               FontSize="30" />
                                    <TextBlock x:Name="FamilyTreeStatusText"
                                               Text="Wähle eine gespeicherte Person aus, um den Stammbaum zu zeichnen."
                                               Classes="body"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Top">
                                    <ComboBox x:Name="FamilyTreeGenerationComboBox"
                                              Classes="project-name"
                                              Width="150"
                                              SelectionChanged="FamilyTreeGenerationComboBox_SelectionChanged" />
                                    <Button Classes="secondary"
                                            Content="-"
                                            Click="ZoomOutTreeButton_Click" />
                                    <Button Classes="secondary"
                                            Content="+"
                                            Click="ZoomInTreeButton_Click" />
                                    <Button Classes="secondary"
                                            Content="Zentrieren"
                                            Click="CenterTreeButton_Click" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1"
                                  ColumnDefinitions="*,360"
                                  ColumnSpacing="16">
                                <Border Background="#EEEEEC"
                                        BorderBrush="#D6D2C8"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        ClipToBounds="True">
                                    <ScrollViewer x:Name="FamilyTreeScrollViewer"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <Canvas x:Name="FamilyTreeCanvas"
                                                Width="900"
                                                Height="520"
                                                Background="#EEEEEC"
                                                PointerWheelChanged="FamilyTreeCanvas_PointerWheelChanged" />
                                    </ScrollViewer>
                                </Border>

                                <Border Grid.Column="1"
                                        Background="#FAFAF7"
                                        BorderBrush="#D6D2C8"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Person im Baum"
                                                   Foreground="{StaticResource InkGreenBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="TreeSelectedPersonText"
                                                   Text="Noch keine Person ausgewählt."
                                                   Classes="body"
                                                   TextWrapping="Wrap" />
                                        <TextBox x:Name="TreeMainNameTextBox"
                                                 Classes="project-name"
                                                 PlaceholderText="Hauptname" />
                                        <TextBox x:Name="TreeAlternativeNamesTextBox"
                                                 Classes="project-name"
                                                 PlaceholderText="Alternative Namen" />
                                        <TextBox x:Name="TreeRoleTextBox"
                                                 Classes="project-name"
                                                 PlaceholderText="Rolle oder Kurzinfo" />
                                        <ComboBox x:Name="TreeGenderComboBox"
                                                  Classes="project-name" />
                                        <ComboBox x:Name="TreeStatusComboBox"
                                                  Classes="project-name" />
                                        <TextBox x:Name="TreeBirthDateTextBox"
                                                 Classes="project-name"
                                                 PlaceholderText="Geburt, z. B. ca. 1380" />
                                        <TextBox x:Name="TreeDeathDateTextBox"
                                                 Classes="project-name"
                                                 PlaceholderText="Tod, z. B. 1449" />
                                        <TextBox x:Name="TreeAgeTextBox"
                                                 Classes="project-name"
                                                 PlaceholderText="Alter, z. B. 69" />
                                        <TextBox x:Name="TreeBirthPlaceTextBox"
                                                 Classes="project-name"
                                                 PlaceholderText="Geburtsort" />
                                        <TextBox x:Name="TreeDeathPlaceTextBox"
                                                 Classes="project-name"
                                                 PlaceholderText="Sterbeort" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <Button Classes="secondary"
                                                    Content="Tod berechnen"
                                                    Click="CalculateDeathFromAgeButton_Click" />
                                            <Button Classes="secondary"
                                                    Content="Geburt berechnen"
                                                    Click="CalculateBirthFromAgeButton_Click" />
                                        </StackPanel>
                                        <TextBox x:Name="TreeShortDescriptionTextBox"
                                                 Classes="project-name"
                                                 PlaceholderText="Kurzbeschreibung"
                                                 MinHeight="64"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap" />
                                        <Button x:Name="TreeSavePersonButton"
                                                Classes="primary"
                                                Content="Person im Stammbaum speichern"
                                                Click="TreeSavePersonButton_Click"
                                                IsEnabled="False" />
                                        <Button x:Name="TreeCancelEditButton"
                                                Classes="secondary"
                                                Content="Änderungen verwerfen"
                                                Click="TreeCancelEditButton_Click"
                                                IsEnabled="False" />
                                        <Button x:Name="TreeAddRelativeButton"
                                                Classes="secondary"
                                                Content="Verwandte hinzufügen"
                                                Click="TreeAddRelativeButton_Click"
                                                IsEnabled="False" />
                                        <TextBlock Text="Beziehungen"
                                                   Foreground="{StaticResource InkGreenBrush}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="TreeParentsText" Text="Eltern: keine" Classes="body" TextWrapping="Wrap" />
                                        <TextBlock x:Name="TreeFocusText" Text="Fokusperson: keine ausgewählt" Classes="body" TextWrapping="Wrap" />
                                        <TextBlock x:Name="TreePartnersText" Text="Partner: keine" Classes="body" TextWrapping="Wrap" />
                                        <TextBlock x:Name="TreeChildrenText" Text="Kinder: keine" Classes="body" TextWrapping="Wrap" />
                                        <TextBlock x:Name="TreeOtherText" Text="Weitere oder unsichere Beziehungen: keine" Classes="body" TextWrapping="Wrap" />
                                        <TextBlock Text="Ereignisse"
                                                   Foreground="{StaticResource InkGreenBrush}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="TreeEventsText" Text="Keine Ereignisse geladen." Classes="body" TextWrapping="Wrap" />
                                        <TextBlock Text="Bibelstellen"
                                                   Foreground="{StaticResource InkGreenBrush}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="TreeBibleReferencesText" Text="Keine Bibelstellen verknüpft." Classes="body" TextWrapping="Wrap" />
                                        <TextBlock Text="Medien / Fotos / PDFs"
                                                   Foreground="{StaticResource InkGreenBrush}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="TreeMediaText" Text="Keine Medien ausgewählt." Classes="body" TextWrapping="Wrap" />
                                        <TextBlock Text="Kommentare / Forschungsnotizen"
                                                   Foreground="{StaticResource InkGreenBrush}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock x:Name="TreeResearchNotesText" Text="Nutze die Kurzbeschreibung als erste Forschungsnotiz; ein eigener Fragenbereich folgt später." Classes="body" TextWrapping="Wrap" />
                                    </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>

                        <Border x:Name="AddRelativeOverlay"
                                IsVisible="False"
                                Background="#CC1B1E1E"
                                CornerRadius="8">
                            <Border Width="520"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="#FAFAF7"
                                    BorderBrush="#D6D2C8"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="20">
                                <StackPanel Spacing="12">
                                    <TextBlock x:Name="AddRelativeTitleText"
                                               Text="Verwandte hinzufügen"
                                               Classes="display"
                                               FontSize="26" />
                                    <TextBlock Text="Wähle die Beziehung zur Person im Baum. Die Beziehung wird gemeinsam mit der neuen Person angelegt."
                                               Classes="body"
                                               TextWrapping="Wrap" />
                                    <ComboBox x:Name="AddRelativeTypeComboBox"
                                              Classes="project-name"
                                              SelectionChanged="AddRelativeTypeComboBox_SelectionChanged" />
                                    <ComboBox x:Name="AddExistingRelationshipTypeComboBox"
                                              Classes="project-name" />
                                    <TextBox x:Name="AddExistingPersonSearchTextBox"
                                             Classes="project-name"
                                             PlaceholderText="Vorhandene Person suchen"
                                             TextChanged="AddExistingPersonSearchTextBox_TextChanged" />
                                    <ComboBox x:Name="AddExistingPersonComboBox"
                                              Classes="project-name" />
                                    <TextBox x:Name="AddRelativeNameTextBox"
                                             Classes="project-name"
                                             PlaceholderText="Hauptname" />
                                    <TextBox x:Name="AddRelativeRoleTextBox"
                                             Classes="project-name"
                                             PlaceholderText="Rolle oder Kurzinfo" />
                                    <TextBox x:Name="AddRelativeBirthDateTextBox"
                                             Classes="project-name"
                                             PlaceholderText="Geburt" />
                                    <TextBox x:Name="AddRelativeDeathDateTextBox"
                                             Classes="project-name"
                                             PlaceholderText="Tod" />
                                    <TextBox x:Name="AddRelativeSourceNoteTextBox"
                                             Classes="project-name"
                                             PlaceholderText="Bibelstelle oder Quellenhinweis" />
                                    <TextBox x:Name="AddRelativeCommentTextBox"
                                             Classes="project-name"
                                             PlaceholderText="Kommentar zur Beziehung"
                                             MinHeight="58"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap" />
                                    <ComboBox x:Name="AddRelativeGenderComboBox"
                                              Classes="project-name" />
                                    <ComboBox x:Name="AddRelativeStatusComboBox"
                                              Classes="project-name" />
                                    <ComboBox x:Name="AddRelativeCertaintyComboBox"
                                              Classes="project-name" />
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="10">
                                        <Button Classes="primary"
                                                Content="Hinzufügen"
                                                Click="SaveRelativeButton_Click" />
                                        <Button Classes="secondary"
                                                Content="Abbrechen"
                                                Click="CancelRelativeButton_Click" />
                                    </StackPanel>
                                    <TextBlock x:Name="AddRelativeStatusText"
                                               Text="Neue Person und Beziehung werden gemeinsam gespeichert."
                                               Classes="body"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Border>
                    </Grid>
                </Border>

                <Grid x:Name="EventsView"
                      ColumnDefinitions="1.05*,0.95*"
                      ColumnSpacing="18">
                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Ereignisse"
                                       Classes="display"
                                       FontSize="28" />
                            <TextBlock Text="Ereignisse der ausgewählten Person"
                                       Classes="body" />
                            <ListBox x:Name="EventsListBox"
                                     MinHeight="180"
                                     SelectionChanged="EventsListBox_SelectionChanged" />
                            <TextBlock x:Name="EventsEmptyText"
                                       Text="Wähle eine Person aus, um Ereignisse zu sehen."
                                       Classes="body" />
                        </StackPanel>
                    </Border>

                    <Border Classes="card">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Ereignis erfassen"
                                       Classes="display"
                                       FontSize="28" />
                            <TextBox x:Name="EventTitleTextBox"
                                     Classes="project-name"
                                     PlaceholderText="Titel" />
                            <ComboBox x:Name="EventTypeComboBox"
                                      Classes="project-name" />
                            <ComboBox x:Name="EventCertaintyComboBox"
                                      Classes="project-name" />
                            <TextBox x:Name="EventDateTextBox"
                                     Classes="project-name"
                                     PlaceholderText="Datierung als Text" />
                            <TextBox x:Name="EventShortDescriptionTextBox"
                                     Classes="project-name"
                                     PlaceholderText="Kurzbeschreibung" />
                            <TextBox x:Name="EventLongDescriptionTextBox"
                                     Classes="project-name"
                                     PlaceholderText="Notizen"
                                     MinHeight="78"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap" />
                            <Button x:Name="SaveEventButton"
                                    Classes="primary"
                                    Content="Ereignis speichern"
                                    Click="SaveEventButton_Click"
                                    IsEnabled="False" />
                            <TextBlock x:Name="EventFormStatusText"
                                       Text="Wähle zuerst eine Person aus."
                                       Classes="body" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="BibleReferencesView"
                      ColumnDefinitions="1.05*,0.95*"
                      ColumnSpacing="18">
                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Bibelstellen"
                                       Classes="display"
                                       FontSize="28" />
                            <TextBlock Text="Eigene Referenzen und Kommentare"
                                       Classes="body" />
                            <ListBox x:Name="BibleReferencesListBox"
                                     MinHeight="180"
                                     SelectionChanged="BibleReferencesListBox_SelectionChanged" />
                            <TextBlock x:Name="BibleReferencesEmptyText"
                                       Text="Noch keine Bibelstellen erfasst."
                                       Classes="body" />
                        </StackPanel>
                    </Border>

                    <Border Classes="card">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Bibelstelle erfassen"
                                       Classes="display"
                                       FontSize="28" />
                            <Grid ColumnDefinitions="*,*"
                                  RowDefinitions="Auto,Auto,Auto"
                                  ColumnSpacing="10"
                                  RowSpacing="10">
                                <TextBox x:Name="BibleTranslationTextBox"
                                         Grid.Row="0"
                                         Grid.Column="0"
                                         Classes="project-name"
                                         PlaceholderText="Übersetzung" />
                                <TextBox x:Name="BibleBookTextBox"
                                         Grid.Row="0"
                                         Grid.Column="1"
                                         Classes="project-name"
                                         PlaceholderText="Buch" />
                                <TextBox x:Name="BibleChapterStartTextBox"
                                         Grid.Row="1"
                                         Grid.Column="0"
                                         Classes="project-name"
                                         PlaceholderText="Kapitel von" />
                                <TextBox x:Name="BibleVerseStartTextBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Classes="project-name"
                                         PlaceholderText="Vers von" />
                                <TextBox x:Name="BibleChapterEndTextBox"
                                         Grid.Row="2"
                                         Grid.Column="0"
                                         Classes="project-name"
                                         PlaceholderText="Kapitel bis" />
                                <TextBox x:Name="BibleVerseEndTextBox"
                                         Grid.Row="2"
                                         Grid.Column="1"
                                         Classes="project-name"
                                         PlaceholderText="Vers bis" />
                            </Grid>
                            <TextBox x:Name="BibleReferenceTextBox"
                                     Classes="project-name"
                                     PlaceholderText="Referenztext oder eigene Abschrift" />
                            <TextBox x:Name="BibleSummaryTextBox"
                                     Classes="project-name"
                                     PlaceholderText="Eigene Zusammenfassung" />
                            <TextBox x:Name="BibleCommentTextBox"
                                     Classes="project-name"
                                     PlaceholderText="Eigener Kommentar"
                                     MinHeight="78"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap" />
                            <Button x:Name="SaveBibleReferenceButton"
                                    Classes="primary"
                                    Content="Bibelstelle speichern"
                                    Click="SaveBibleReferenceButton_Click"
                                    IsEnabled="False" />
                            <TextBlock x:Name="BibleReferenceFormStatusText"
                                       Text="Öffne oder erstelle zuerst ein Projekt."
                                       Classes="body" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="MediaView"
                      ColumnDefinitions="1.05*,0.95*"
                      ColumnSpacing="18">
                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Mediathek"
                                       Classes="display"
                                       FontSize="28" />
                            <TextBlock Text="Bilder, PDFs und lokale Projektdateien"
                                       Classes="body" />
                            <TextBox x:Name="MediaSearchTextBox"
                                     Classes="project-name"
                                     PlaceholderText="Medien suchen"
                                     TextChanged="MediaSearchTextBox_TextChanged" />
                            <ListBox x:Name="MediaFilesListBox"
                                     MinHeight="180"
                                     SelectionChanged="MediaFilesListBox_SelectionChanged" />
                            <TextBlock x:Name="MediaFilesEmptyText"
                                       Text="Noch keine Medien importiert."
                                       Classes="body" />
                        </StackPanel>
                    </Border>

                    <Border Classes="card">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Medium bearbeiten"
                                       Classes="display"
                                       FontSize="28" />
                            <TextBlock x:Name="SelectedMediaText"
                                       Text="Kein Medium ausgewählt."
                                       Classes="body"
                                       TextWrapping="Wrap" />
                            <TextBox x:Name="MediaDescriptionTextBox"
                                     Classes="project-name"
                                     PlaceholderText="Beschreibung"
                                     MinHeight="72"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap" />
                            <Button x:Name="ImportMediaButton"
                                    Classes="primary"
                                    Content="Datei importieren"
                                    Click="ImportMediaButton_Click"
                                    IsEnabled="False" />
                            <Button x:Name="SaveMediaButton"
                                    Classes="secondary"
                                    Content="Beschreibung speichern"
                                    Click="SaveMediaButton_Click"
                                    IsEnabled="False" />
                            <Button x:Name="LinkMediaToPersonButton"
                                    Classes="secondary"
                                    Content="Mit Person verknüpfen"
                                    Click="LinkMediaToPersonButton_Click"
                                    IsEnabled="False" />
                            <Button x:Name="LinkMediaToEventButton"
                                    Classes="secondary"
                                    Content="Mit Ereignis verknüpfen"
                                    Click="LinkMediaToEventButton_Click"
                                    IsEnabled="False" />
                            <Button x:Name="SetPortraitButton"
                                    Classes="secondary"
                                    Content="Als Portrait setzen"
                                    Click="SetPortraitButton_Click"
                                    IsEnabled="False" />
                            <TextBlock x:Name="MediaFormStatusText"
                                       Text="Öffne oder erstelle zuerst ein Projekt."
                                       Classes="body"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border x:Name="MapPlaceholderView"
                        Classes="card">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Karte (bald)"
                                   Classes="display"
                                   FontSize="30" />
                        <TextBlock Text="Die Kartenansicht ist noch nicht umgesetzt. Später sollen hier Orte, Reisen und Ereignisse räumlich verbunden werden."
                                   Classes="body"
                                   TextWrapping="Wrap" />
                        <Button Classes="secondary"
                                Content="Kartenmodul noch nicht umgesetzt"
                                IsEnabled="False" />
                    </StackPanel>
                </Border>

                <Border x:Name="PlacesPlaceholderView"
                        Classes="card">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Orte (bald)"
                                   Classes="display"
                                   FontSize="30" />
                        <TextBlock Text="Die Ortsverwaltung ist noch nicht umgesetzt. In einem späteren Schritt werden Orte, Regionen und Fundstellen hier gepflegt."
                                   Classes="body"
                                   TextWrapping="Wrap" />
                        <Button Classes="secondary"
                                Content="Ortsmodul noch nicht umgesetzt"
                                IsEnabled="False" />
                    </StackPanel>
                </Border>

                <Border x:Name="ResearchQuestionsPlaceholderView"
                        Classes="card">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Forschungsfragen (bald)"
                                   Classes="display"
                                   FontSize="30" />
                        <TextBlock Text="Forschungsfragen sind noch nicht umgesetzt. Später sollen offene Fragen, Hypothesen und Klärungen hier gesammelt werden."
                                   Classes="body"
                                   TextWrapping="Wrap" />
                        <Button Classes="secondary"
                                Content="Forschungsmodul noch nicht umgesetzt"
                                IsEnabled="False" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
